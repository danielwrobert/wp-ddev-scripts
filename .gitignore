# ignore everything in the "wp-content" directory
# unless explicitly allowed at the end of this file
wp-content/plugins/*
wp-content/themes/*
# web/wp-content/mu-plugins/*
wp-content/cache
wp-content/uploads

# Custom plugins/themes need to be explicitly excluded from being ignored so they can be committed.
# themes
!web/wp-content/themes/mirkwood/

# AMCA blocks plugin
!web/wp-content/plugins/mirkwood-blocks/